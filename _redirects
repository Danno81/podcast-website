# Proxy YouTube RSS feed through your own domain — avoids CORS and third-party
# proxy blocking. The fallback page fetches /youtube-rss instead of going
# directly to YouTube (which browsers block) or via a CORS proxy (unreliable).
/youtube-rss  https://www.youtube.com/feeds/videos.xml?channel_id=UCiTc9fbcfRCP92xhTZBXr2Q  200

# Fallback for episode pages not yet generated by generate.js.
# Netlify only applies this when the static file does NOT exist (200 rewrite).
/ep/*  /episode-fallback.html  200
